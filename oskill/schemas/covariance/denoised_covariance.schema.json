{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "denoised_covariance",
  "description": "Random Matrix Theory denoising of covariance matrix output schema",
  "type": "object",
  "properties": {
    "returns": {
      "description": "T x N returns matrix (T >= N + 10)",
      "type": "array",
      "items": { "type": "array", "items": { "type": "number" } }
    },
    "method": {
      "description": "Denoising method",
      "type": "string",
      "enum": ["mp_filter", "constant_residual"],
      "default": "mp_filter"
    },
    "bandwidth": {
      "description": "Optional KDE bandwidth parameter",
      "type": ["number", "null"],
      "default": null
    }
  },
  "required": ["returns"],
  "output": {
    "type": "object",
    "properties": {
      "covariance": {
        "description": "N x N denoised covariance matrix (PSD)",
        "type": "array"
      },
      "correlation": {
        "description": "N x N denoised correlation matrix",
        "type": "array"
      },
      "eigenvalues_original": {
        "description": "N original eigenvalues of correlation matrix (ascending)",
        "type": "array",
        "items": { "type": "number" }
      },
      "eigenvalues_denoised": {
        "description": "N denoised eigenvalues",
        "type": "array",
        "items": { "type": "number" }
      },
      "lambda_plus": {
        "description": "Marchenko-Pastur upper bound (1 + sqrt(N/T))^2",
        "type": "number"
      },
      "n_signal_eigenvalues": {
        "description": "Number of signal (non-noise) eigenvalues > lambda_plus",
        "type": "integer",
        "minimum": 0
      }
    },
    "required": ["covariance", "correlation", "eigenvalues_original",
                 "eigenvalues_denoised", "lambda_plus", "n_signal_eigenvalues"]
  },
  "references": [
    "López de Prado (2020), 'Machine Learning for Asset Managers', Ch.2",
    "Marchenko & Pastur (1967)"
  ]
}
