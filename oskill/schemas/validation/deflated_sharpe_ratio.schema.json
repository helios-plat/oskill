{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "deflated_sharpe_ratio",
  "description": "Deflated Sharpe Ratio (DSR) correcting for selection bias",
  "type": "object",
  "properties": {
    "sharpe_ratios": {
      "description": "List of observed Sharpe ratios (one per candidate strategy)",
      "type": "array",
      "items": { "type": "number" },
      "minItems": 1
    },
    "n_observations": {
      "description": "Number of time-series observations used",
      "type": "integer",
      "minimum": 2
    },
    "skewness": {
      "description": "Return distribution skewness (default 0 = normal)",
      "type": "number",
      "default": 0.0
    },
    "kurtosis": {
      "description": "Return distribution kurtosis (default 3 = normal)",
      "type": "number",
      "default": 3.0
    },
    "candidates_tried": {
      "description": "Number of candidates tried (overrides len(sharpe_ratios))",
      "type": ["integer", "null"],
      "minimum": 1,
      "default": null
    }
  },
  "required": ["sharpe_ratios", "n_observations"],
  "output": {
    "type": "object",
    "properties": {
      "dsr_probability": {
        "description": "Probability the strategy is genuinely skilled (DSR CDF)",
        "type": "number",
        "minimum": 0,
        "maximum": 1
      },
      "observed_sharpe": {
        "description": "Maximum observed Sharpe ratio",
        "type": "number"
      },
      "expected_max_sharpe": {
        "description": "E[max(SR)] under null hypothesis (no skill)",
        "type": "number"
      },
      "sharpe_variance": {
        "description": "Estimated variance of the SR estimator",
        "type": "number",
        "minimum": 0
      },
      "is_significant": {
        "description": "True if dsr_probability > 0.95",
        "type": "boolean"
      }
    },
    "required": ["dsr_probability", "observed_sharpe", "expected_max_sharpe",
                 "sharpe_variance", "is_significant"]
  },
  "references": [
    "Bailey & López de Prado (2014), 'The Deflated Sharpe Ratio'",
    "Journal of Portfolio Management, 40(5), 94-107"
  ]
}
