{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "oskill:market_rules_backtest_input",
  "title": "Market Rules Backtest Input",
  "description": "Input schema for market_rules_backtest_run.",
  "type": "object",
  "required": ["signals", "ohlcv_by_symbol", "market_rules"],
  "properties": {
    "signals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["date", "symbol", "direction"],
        "properties": {
          "date": { "type": "string", "format": "date" },
          "symbol": { "type": "string" },
          "direction": { "type": "string", "enum": ["buy", "sell"] },
          "quantity": { "type": "number", "minimum": 0 },
          "price": { "type": "number", "minimum": 0 }
        }
      }
    },
    "ohlcv_by_symbol": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["date", "open", "high", "low", "close", "volume"],
          "properties": {
            "date": { "type": "string" },
            "open": { "type": "number" },
            "high": { "type": "number" },
            "low": { "type": "number" },
            "close": { "type": "number" },
            "volume": { "type": "number", "minimum": 0 }
          }
        }
      }
    },
    "market_rules": {
      "type": "object",
      "properties": {
        "t_plus_n": { "type": "integer", "minimum": 0 },
        "limit_pct": { "type": "number", "minimum": 0 },
        "commission_rate": { "type": "number", "minimum": 0 },
        "min_commission": { "type": "number", "minimum": 0 },
        "stamp_tax_rate": { "type": "number", "minimum": 0 },
        "stamp_tax_direction": { "type": "string", "enum": ["buy", "sell", "both"] }
      }
    },
    "initial_capital": {
      "type": "number",
      "minimum": 0,
      "default": 1000000
    }
  },
  "additionalProperties": false
}
