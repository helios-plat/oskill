{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://3o-spec.org/schemas/oskill/llm/deterministic_call.schema.json",
  "title": "DeterministicLLMCall Output",
  "type": "object",
  "required": ["response", "prompt_rendered", "prompt_fingerprint", "model", "temperature", "seed", "response_format", "metadata", "timestamp_called"],
  "properties": {
    "response": {
      "description": "LLM response content (string or parsed dict if response_format=json)"
    },
    "prompt_rendered": {
      "type": "string",
      "description": "Fully rendered prompt after variable substitution"
    },
    "prompt_fingerprint": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "SHA-256 hex of canonical(template + variables + model + temperature + seed)"
    },
    "model": {
      "type": "string"
    },
    "temperature": {
      "type": "number",
      "minimum": 0
    },
    "seed": {
      "type": ["integer", "null"]
    },
    "response_format": {
      "type": "string",
      "enum": ["text", "json"]
    },
    "metadata": {
      "type": "object",
      "required": ["input_tokens", "output_tokens", "stop_reason"],
      "properties": {
        "input_tokens": {"type": ["integer", "null"]},
        "output_tokens": {"type": ["integer", "null"]},
        "stop_reason": {"type": ["string", "null"]}
      }
    },
    "timestamp_called": {
      "type": "string",
      "description": "ISO 8601 UTC timestamp"
    }
  }
}
