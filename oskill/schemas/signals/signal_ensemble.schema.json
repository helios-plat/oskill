{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://3o-spec.org/schemas/oskill/signals/signal_ensemble.schema.json",
  "title": "SignalEnsemble Input",
  "type": "object",
  "required": ["signals", "weights"],
  "properties": {
    "signals": {
      "type": "object",
      "description": "Map of signal_name -> time-aligned signal values, each in [-1, 1]",
      "minProperties": 1,
      "additionalProperties": {
        "type": "array",
        "items": {"type": "number", "minimum": -1, "maximum": 1}
      }
    },
    "weights": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {"type": "number", "minimum": 0}
    },
    "decay_lookback": {
      "type": "integer",
      "minimum": 0,
      "default": 0
    },
    "aggregation": {
      "type": "string",
      "enum": ["linear", "geometric", "harmonic"],
      "default": "linear"
    }
  }
}
