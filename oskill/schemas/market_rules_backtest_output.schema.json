{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "oskill:market_rules_backtest_output",
  "title": "Market Rules Backtest Output",
  "description": "Output schema for market_rules_backtest_run.",
  "type": "object",
  "required": ["trades", "equity_curve", "metrics", "blocked_signals"],
  "properties": {
    "trades": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "symbol": { "type": "string" },
          "buy_date": { "type": "string" },
          "sell_date": { "type": "string" },
          "buy_price": { "type": "number" },
          "sell_price": { "type": "number" },
          "quantity": { "type": "number" },
          "gross_pnl": { "type": "number" },
          "commission_paid": { "type": "number" },
          "stamp_tax_paid": { "type": "number" },
          "net_pnl": { "type": "number" },
          "realized_pnl_pct": { "type": "number" }
        }
      }
    },
    "equity_curve": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "date": { "type": "string" },
          "equity": { "type": "number" }
        }
      }
    },
    "metrics": {
      "type": "object",
      "properties": {
        "total_return_pct": { "type": "number" },
        "n_trades": { "type": "integer" },
        "n_blocked": { "type": "integer" },
        "win_rate": { "type": "number" },
        "avg_pnl_pct": { "type": "number" }
      }
    },
    "blocked_signals": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "signal": { "type": "object" },
          "reason": { "type": "string" }
        }
      }
    }
  },
  "additionalProperties": false
}
