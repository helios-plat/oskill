{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "oskill:dsl_rule",
  "title": "DSL Rule",
  "description": "Schema for a DSL-based rule used in dsl_rule_validate / dsl_rule_evaluate.",
  "type": "object",
  "required": ["rule_id", "triggers"],
  "properties": {
    "rule_id": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "triggers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "params": { "type": "object" }
        }
      }
    },
    "filters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "params": { "type": "object" }
        }
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "params": { "type": "object" }
        }
      }
    },
    "priority": {
      "type": "integer",
      "minimum": 0
    },
    "enabled": {
      "type": "boolean",
      "default": true
    }
  },
  "additionalProperties": false
}
